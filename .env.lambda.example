# Shurly Lambda Environment Configuration
# Copy this to your Lambda function's environment variables

# Database Configuration (RDS PostgreSQL)
DB_HOST=your-rds-endpoint.region.rds.amazonaws.com
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-secure-password-here
DB_NAME=shurly

# JWT Configuration
JWT_SECRET_KEY=your-production-secret-key-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# API Configuration
API_TITLE=Shurly API
API_VERSION=0.1.0
API_DESCRIPTION=A modern URL shortener API

# CORS Configuration (JSON array for production domains)
CORS_ORIGINS=["https://shurl.griddo.io","https://www.griddo.io"]

# Lambda-specific Settings
IS_LAMBDA=true
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600
DB_SSL_MODE=require

# Phase 3.9.5 — GDPR. Truncate visitor IPs at insert time (IPv4 → /24, IPv6 → /64).
# Keep ON for production unless legal review explicitly approves storing full addresses.
ANONYMIZE_REMOTE_ADDR=true

# Phase 3.9.6 — Trusted-proxy allowlist for X-Forwarded-For. JSON array of CIDRs.
# REQUIRED in production: without this, the Lambda will see the API Gateway IP on
# every visit and visit IPs will be wrong. See DEPLOYMENT.md "Trusted-Proxy
# Configuration" for ALB/CloudFront/API-Gateway recipes.
TRUSTED_PROXIES=[]

# Phase 3.9.6 — Query string that suppresses Visitor logging while still redirecting.
# Useful for synthetic monitoring / smoke tests so they don't pollute analytics.
DISABLE_TRACK_PARAM=nostat

# Phase 3.9.6 — Short-code casing mode. "loose" lowercases generated codes and
# custom slugs at insert time (Shlink default). "strict" preserves case.
SHORT_URL_MODE=loose

# Phase 3.10.1 — Default short-link host. Seeded as the default Domain row at
# startup. Set this to the host this Lambda actually serves before launch.
DEFAULT_DOMAIN=shurl.griddo.io

# Phase 3.10.6 — Redirect HTTP status code (301 / 302 / 307 / 308).
# 302 keeps every hit reaching the backend (analytics-friendly).
# 301 is SEO-friendly but cached aggressively (analytics fidelity drops).
REDIRECT_STATUS_CODE=302

# Phase 3.10.6 — Seconds the redirect response may be cached at the edge.
# 0 emits "Cache-Control: private, max-age=0" (every hit logged).
# Positive values emit "Cache-Control: public, max-age=N" — trades analytics
# fidelity for redirect latency.
REDIRECT_CACHE_LIFETIME=0

# Optional: Base URL for short links (used in campaign exports and email notifications)
# BASE_URL=https://shurl.griddo.io
