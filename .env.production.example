# Shurly Production Environment Configuration
#
# These variables are wired to the ECS task definition (see scripts/deploy_ecs.sh
# and the SAM-style call to `aws ecs create-express-gateway-service`). For local
# Docker testing, copy this file to `.env` and `docker run --env-file .env ...`.
#
# Sensitive values (DB_PASSWORD, JWT_SECRET_KEY) belong in AWS Secrets Manager
# in production — the deploy script reads them from Secrets and injects at
# task-launch time. Never commit real values.

# ─── Database (RDS PostgreSQL) ──────────────────────────────────────────────
DB_HOST=shurly-db.xxxxx.eu-south-2.rds.amazonaws.com
DB_PORT=5432
DB_USER=shurly
DB_PASSWORD=set-from-secrets-manager
DB_NAME=shurly
DB_SSL_MODE=require

# Connection pool sizing. ECS Fargate keeps the process alive across requests
# so a healthy pool is reused; 10/20 mirrors the local dev defaults and works
# fine for one task. Bump if you scale up the task or add concurrency.
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=set-from-secrets-manager
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ─── API metadata ────────────────────────────────────────────────────────────
API_TITLE=Shurly API
API_VERSION=0.1.0
API_DESCRIPTION=A modern URL shortener API

# ─── CORS ────────────────────────────────────────────────────────────────────
# JSON array of allowed origins. The frontend host comes online in Phase 7;
# until then the API is consumed by Claude Code (MCP, Phase 5) and other
# server-side callers that don't need CORS — but keep the placeholder.
CORS_ORIGINS=["https://shurl.griddo.io"]

# ─── Phase 3.9.5 — GDPR ──────────────────────────────────────────────────────
# Truncate visitor IPs at insert time (IPv4 → /24, IPv6 → /64). Keep ON unless
# legal review explicitly approves storing full addresses.
ANONYMIZE_REMOTE_ADDR=true

# ─── Phase 3.9.6 — Trust boundaries for X-Forwarded-For ─────────────────────
# JSON array of CIDRs. REQUIRED in production: without this the application
# records the ALB's IP for every visit and the real client IP is lost. The
# default VPC's CIDR for griddo-main is 172.31.0.0/16; the shared ALB lives
# inside that network. Add any extra edges (CloudFront, custom proxies) here.
TRUSTED_PROXIES=["172.31.0.0/16"]

# ─── Phase 3.9.6 — Visit-suppression query param ────────────────────────────
DISABLE_TRACK_PARAM=nostat

# ─── Phase 3.9.6 — Short-code casing ────────────────────────────────────────
# `loose` lowercases generated codes and custom slugs at insert (Shlink default).
# `strict` preserves case. Once you ship URLs in `loose` mode you cannot flip
# back without breaking existing links.
SHORT_URL_MODE=loose

# ─── Phase 3.10.1 — Default short-link host ─────────────────────────────────
# Seeded as the default Domain row on first startup. URLs created without an
# explicit domain_id are bound to this host.
DEFAULT_DOMAIN=s.griddo.io

# ─── Phase 3.10.6 — Redirect behavior ────────────────────────────────────────
# 302 keeps every hit reaching the backend (analytics-friendly).
# 301 is SEO-friendly but cached aggressively (analytics fidelity drops).
# 307/308 preserve the request method.
REDIRECT_STATUS_CODE=302

# Edge cache lifetime in seconds. 0 → "Cache-Control: private, max-age=0".
# Positive values trade analytics fidelity for redirect latency.
REDIRECT_CACHE_LIFETIME=0
