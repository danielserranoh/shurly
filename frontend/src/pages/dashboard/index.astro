---
import Layout from '@/layouts/Layout.astro';
import Navbar from '@/components/Navbar.astro';
import ProtectedRoute from '@/components/ProtectedRoute.astro';
import URLCard from '@/components/URLCard.astro';
---

<Layout title="Dashboard - Shurly">
  <ProtectedRoute>
    <div id="dashboard-navbar"></div>

    <main class="min-h-screen bg-gray-50 py-8">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Header -->
        <div class="mb-8">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
              <h1 class="text-3xl font-bold text-gray-900">
                Your URLs
              </h1>
              <p class="mt-1 text-sm text-gray-600" id="user-email"></p>
            </div>
            <a
              href="/dashboard/create"
              class="inline-flex items-center justify-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 transition-colors shadow-sm"
            >
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
              </svg>
              Create Short URL
            </a>
          </div>
        </div>

        <!-- Stats -->
        <div class="mb-8 grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div class="bg-white rounded-lg shadow p-6">
            <div class="flex items-center">
              <div class="flex-shrink-0">
                <svg class="h-8 w-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
                </svg>
              </div>
              <div class="ml-4">
                <p class="text-sm font-medium text-gray-600">Total URLs</p>
                <p class="text-2xl font-semibold text-gray-900" id="total-urls">0</p>
              </div>
            </div>
          </div>

          <div class="bg-white rounded-lg shadow p-6">
            <div class="flex items-center">
              <div class="flex-shrink-0">
                <svg class="h-8 w-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                </svg>
              </div>
              <div class="ml-4">
                <p class="text-sm font-medium text-gray-600">Total Clicks</p>
                <p class="text-2xl font-semibold text-gray-900" id="total-clicks">0</p>
              </div>
            </div>
          </div>

          <div class="bg-white rounded-lg shadow p-6">
            <div class="flex items-center">
              <div class="flex-shrink-0">
                <svg class="h-8 w-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
                </svg>
              </div>
              <div class="ml-4">
                <p class="text-sm font-medium text-gray-600">Custom URLs</p>
                <p class="text-2xl font-semibold text-gray-900" id="custom-urls">0</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Loading State -->
        <div id="loading" class="text-center py-12">
          <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600 mx-auto"></div>
          <p class="mt-4 text-gray-600">Loading your URLs...</p>
        </div>

        <!-- Empty State -->
        <div id="empty-state" class="hidden text-center py-12">
          <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
          </svg>
          <h3 class="mt-2 text-sm font-medium text-gray-900">No URLs yet</h3>
          <p class="mt-1 text-sm text-gray-500">Get started by creating your first short URL.</p>
          <div class="mt-6">
            <a
              href="/dashboard/create"
              class="inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700"
            >
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
              </svg>
              Create Short URL
            </a>
          </div>
        </div>

        <!-- URLs List -->
        <div id="urls-list" class="hidden grid grid-cols-1 gap-6">
          <!-- URLCards will be inserted here dynamically -->
        </div>
      </div>
    </main>

    <!-- Delete Confirmation Modal -->
    <div id="delete-modal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
      <div class="bg-white rounded-lg p-6 max-w-md w-full mx-4">
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Delete URL?</h3>
        <p class="text-gray-600 mb-1">
          Are you sure you want to delete <strong id="delete-url-name" class="text-gray-900"></strong>?
        </p>
        <p class="text-sm text-gray-500 mb-6">This action cannot be undone.</p>
        <div class="flex gap-3 justify-end">
          <button
            id="cancel-delete"
            class="px-4 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors font-medium"
          >
            Cancel
          </button>
          <button
            id="confirm-delete"
            class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors font-medium"
          >
            Delete
          </button>
        </div>
      </div>
    </div>
  </ProtectedRoute>

  <script>
    import { apiGet } from '@/utils/api';
    import type { User, URLListResponse } from '@/utils/types';

    const loading = document.getElementById('loading') as HTMLDivElement;
    const emptyState = document.getElementById('empty-state') as HTMLDivElement;
    const urlsList = document.getElementById('urls-list') as HTMLDivElement;
    const userEmailEl = document.getElementById('user-email') as HTMLParagraphElement;
    const totalUrlsEl = document.getElementById('total-urls') as HTMLParagraphElement;
    const totalClicksEl = document.getElementById('total-clicks') as HTMLParagraphElement;
    const customUrlsEl = document.getElementById('custom-urls') as HTMLParagraphElement;
    const dashboardNavbar = document.getElementById('dashboard-navbar') as HTMLDivElement;

    async function loadDashboard() {
      try {
        // Fetch user info
        const user = await apiGet<User>('/api/v1/auth/me', true);
        userEmailEl.textContent = user.email;

        // Render navbar with user email
        const navbarHTML = `
          <nav class="bg-white shadow-sm border-b border-gray-200">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
              <div class="flex justify-between items-center h-16">
                <div class="flex-shrink-0">
                  <a href="/" class="text-2xl font-bold text-blue-600 hover:text-blue-700 transition-colors">
                    Shurly
                  </a>
                </div>
                <div class="flex items-center space-x-4">
                  <span class="text-sm text-gray-600 hidden sm:inline">
                    ${user.email}
                  </span>
                  <a
                    href="/dashboard"
                    class="text-gray-700 hover:text-blue-600 transition-colors font-medium"
                  >
                    Dashboard
                  </a>
                  <button
                    id="logout-btn"
                    class="bg-red-600 text-white px-4 py-2 rounded-lg hover:bg-red-700 transition-colors font-medium text-sm"
                  >
                    Logout
                  </button>
                </div>
              </div>
            </div>
          </nav>
        `;
        dashboardNavbar.innerHTML = navbarHTML;

        // Add logout functionality
        const logoutBtn = document.getElementById('logout-btn');
        if (logoutBtn) {
          logoutBtn.addEventListener('click', () => {
            import('@/utils/auth').then(({ logout }) => logout());
          });
        }

        // Fetch URLs
        const data = await apiGet<URLListResponse>('/api/v1/urls?skip=0&limit=100', true);

        // Update stats
        totalUrlsEl.textContent = data.total.toString();
        const totalClicks = data.urls.reduce((sum, url) => sum + (url.click_count || 0), 0);
        totalClicksEl.textContent = totalClicks.toString();
        const customUrls = data.urls.filter(url => url.url_type === 'custom').length;
        customUrlsEl.textContent = customUrls.toString();

        // Hide loading
        loading.classList.add('hidden');

        if (data.urls.length === 0) {
          emptyState.classList.remove('hidden');
        } else {
          urlsList.classList.remove('hidden');

          // Render URLs
          data.urls.forEach(url => {
            const urlCard = document.createElement('div');
            urlCard.innerHTML = `
              <div class="bg-white rounded-lg shadow-md border border-gray-200 p-6 hover:shadow-lg transition-shadow">
                <div class="space-y-4">
                  <div>
                    <label class="text-xs text-gray-500 uppercase tracking-wide font-semibold">
                      Short URL
                    </label>
                    <div class="flex items-center gap-2 mt-1">
                      <a
                        href="${url.short_url}"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-blue-600 hover:text-blue-700 font-medium text-lg flex-1 truncate"
                      >
                        ${url.short_url}
                      </a>
                      <button
                        class="copy-btn bg-blue-600 text-white px-3 py-1.5 rounded-md hover:bg-blue-700 transition-colors text-sm font-medium"
                        data-url="${url.short_url}"
                      >
                        Copy
                      </button>
                    </div>
                  </div>
                  <div>
                    <label class="text-xs text-gray-500 uppercase tracking-wide font-semibold">
                      Original URL
                    </label>
                    <a
                      href="${url.original_url}"
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-gray-700 hover:text-blue-600 block mt-1 truncate"
                      title="${url.original_url}"
                    >
                      ${url.original_url}
                    </a>
                  </div>
                  <div class="flex items-center justify-between text-sm text-gray-500 pt-2 border-t border-gray-200">
                    <div class="flex items-center gap-4">
                      <span class="flex items-center gap-1">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                        </svg>
                        ${url.click_count || 0} clicks
                      </span>
                      <span class="flex items-center gap-1">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
                        </svg>
                        ${url.url_type}
                      </span>
                    </div>
                    <span class="flex items-center gap-1">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                      </svg>
                      ${new Date(url.created_at).toLocaleDateString('en-US', {
                        year: 'numeric',
                        month: 'short',
                        day: 'numeric',
                      })}
                    </span>
                  </div>
                </div>
              </div>
            `;
            urlsList.appendChild(urlCard);
          });

          // Add copy functionality
          const copyButtons = document.querySelectorAll('.copy-btn');
          copyButtons.forEach(button => {
            button.addEventListener('click', async (e) => {
              const btn = e.target as HTMLButtonElement;
              const url = btn.dataset.url;

              if (!url) return;

              try {
                await navigator.clipboard.writeText(url);
                const originalText = btn.textContent;
                btn.textContent = 'Copied!';
                btn.classList.add('bg-green-600', 'hover:bg-green-700');
                btn.classList.remove('bg-blue-600', 'hover:bg-blue-700');

                setTimeout(() => {
                  btn.textContent = originalText;
                  btn.classList.remove('bg-green-600', 'hover:bg-green-700');
                  btn.classList.add('bg-blue-600', 'hover:bg-blue-700');
                }, 2000);
              } catch (error) {
                console.error('Failed to copy:', error);
              }
            });
          });

          // Add delete functionality
          const deleteButtons = document.querySelectorAll('.delete-btn');
          deleteButtons.forEach(button => {
            button.addEventListener('click', (e) => {
              const btn = e.target as HTMLButtonElement;
              const shortCode = btn.dataset.shortCode;
              const shortUrl = btn.dataset.shortUrl;

              if (!shortCode || !shortUrl) return;

              // Show modal
              const modal = document.getElementById('delete-modal')!;
              const urlName = document.getElementById('delete-url-name')!;
              urlName.textContent = shortUrl;

              // Store the short code for deletion
              (window as any).deleteShortCode = shortCode;
              modal.classList.remove('hidden');
            });
          });
        }
      } catch (error) {
        console.error('Failed to load dashboard:', error);
        loading.innerHTML = `
          <div class="text-center text-red-600">
            <p>Failed to load dashboard. Please try again.</p>
          </div>
        `;
      }
    }

    // Delete modal handlers
    const deleteModal = document.getElementById('delete-modal')!;
    const cancelDeleteBtn = document.getElementById('cancel-delete')!;
    const confirmDeleteBtn = document.getElementById('confirm-delete')!;

    cancelDeleteBtn.addEventListener('click', () => {
      deleteModal.classList.add('hidden');
      (window as any).deleteShortCode = null;
    });

    confirmDeleteBtn.addEventListener('click', async () => {
      const shortCode = (window as any).deleteShortCode;
      if (!shortCode) return;

      try {
        // Disable button during deletion
        confirmDeleteBtn.disabled = true;
        confirmDeleteBtn.textContent = 'Deleting...';

        await apiDelete(`/api/v1/urls/${shortCode}`, true);

        // Hide modal
        deleteModal.classList.add('hidden');
        (window as any).deleteShortCode = null;

        // Reload dashboard
        window.location.reload();
      } catch (error) {
        console.error('Failed to delete URL:', error);
        alert('Failed to delete URL. Please try again.');
        confirmDeleteBtn.disabled = false;
        confirmDeleteBtn.textContent = 'Delete';
      }
    });

    // Import apiDelete
    import { apiDelete } from '@/utils/api';

    loadDashboard();
  </script>
</Layout>
