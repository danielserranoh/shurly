---
import ProtectedRoute from '@/components/ProtectedRoute.astro';
import Navbar from '@/components/Navbar.astro';

const title = 'URL Details | Shurly';
---

<ProtectedRoute>
  <!DOCTYPE html>
  <html lang="en">
    <head>
      <meta charset="UTF-8" />
      <meta name="viewport" content="width=device-width, initial-scale=1.0" />
      <title>{title}</title>
    </head>
    <body class="bg-gray-50 min-h-screen">
      <Navbar />

      <main class="container mx-auto px-4 py-8 max-w-6xl">
        <!-- Loading State -->
        <div id="loading-container" class="flex items-center justify-center py-12">
          <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600"></div>
          <span class="ml-3 text-gray-600">Loading URL details...</span>
        </div>

        <!-- Error State -->
        <div id="error-container" class="hidden">
          <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-4">
            <p class="text-red-800" id="error-message">Failed to load URL details</p>
          </div>
          <a
            href="/dashboard"
            class="text-blue-600 hover:text-blue-700 text-sm font-medium"
          >
            ← Back to Dashboard
          </a>
        </div>

        <!-- URL Details -->
        <div id="url-container" class="hidden">
          <div class="mb-6">
            <a
              href="/dashboard"
              class="text-blue-600 hover:text-blue-700 text-sm font-medium"
            >
              ← Back to Dashboard
            </a>
          </div>

          <!-- Header -->
          <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-6">
            <div class="flex items-start justify-between mb-4">
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-2">
                  <h1 id="url-short-code" class="text-2xl font-bold text-gray-900"></h1>
                  <span id="url-type-badge" class="px-3 py-1 rounded-full text-xs font-medium"></span>
                </div>
                <p id="url-original" class="text-gray-600 break-all"></p>
              </div>
              <div class="flex gap-2 ml-4">
                <button
                  id="copy-btn"
                  class="px-4 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors font-medium text-sm"
                >
                  Copy Link
                </button>
                <button
                  id="delete-btn"
                  class="px-4 py-2 border border-red-300 text-red-700 rounded-lg hover:bg-red-50 transition-colors font-medium text-sm"
                >
                  Delete
                </button>
              </div>
            </div>

            <div class="flex items-center gap-6 text-sm text-gray-500">
              <div>
                <span class="font-medium">Created:</span>
                <span id="url-created" class="ml-1"></span>
              </div>
              <div id="url-warning" class="hidden text-amber-600">
                <svg class="inline w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                </svg>
                <span id="warning-text"></span>
              </div>
            </div>
          </div>

          <!-- Stats Cards -->
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
            <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
              <div class="text-sm text-gray-500 mb-1">Total Clicks</div>
              <div id="stat-total-clicks" class="text-3xl font-bold text-gray-900">0</div>
            </div>
            <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
              <div class="text-sm text-gray-500 mb-1">Clicks (7 days)</div>
              <div id="stat-recent-clicks" class="text-3xl font-bold text-gray-900">0</div>
            </div>
            <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
              <div class="text-sm text-gray-500 mb-1">Unique Visitors</div>
              <div id="stat-unique-visitors" class="text-3xl font-bold text-gray-900">0</div>
            </div>
          </div>

          <!-- Analytics Chart -->
          <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-6">
            <h2 class="text-lg font-semibold text-gray-900 mb-4">Click Activity (Last 7 Days)</h2>
            <div id="chart-container" class="h-64">
              <!-- Simple bar chart -->
              <div class="flex items-end justify-between h-full gap-2">
                <div id="chart-bars" class="flex items-end justify-between h-full w-full gap-2"></div>
              </div>
            </div>
            <div id="chart-labels" class="flex justify-between mt-2 text-xs text-gray-500"></div>
          </div>

          <!-- Geographic Distribution -->
          <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-6">
            <h2 class="text-lg font-semibold text-gray-900 mb-4">Geographic Distribution</h2>
            <div id="geo-container">
              <div id="geo-loading" class="flex items-center justify-center py-8">
                <div class="animate-spin rounded-full h-6 w-6 border-b-2 border-blue-600"></div>
                <span class="ml-2 text-gray-600 text-sm">Loading geographic data...</span>
              </div>
              <div id="geo-stats" class="hidden space-y-2"></div>
              <div id="geo-empty" class="hidden text-center py-8 text-gray-500 text-sm">
                No geographic data available yet
              </div>
            </div>
          </div>

          <!-- Campaign Info (if applicable) -->
          <div id="campaign-info" class="hidden bg-blue-50 rounded-lg border border-blue-200 p-6">
            <h3 class="text-sm font-medium text-blue-900 mb-2">Campaign URL</h3>
            <p class="text-sm text-blue-800">
              This URL is part of the campaign: <a id="campaign-link" href="#" class="font-semibold hover:underline"></a>
            </p>
            <div id="user-data-container" class="mt-4">
              <h4 class="text-sm font-medium text-blue-900 mb-2">User Data:</h4>
              <div id="user-data-tags" class="flex flex-wrap gap-2"></div>
            </div>
          </div>
        </div>

        <!-- Delete Confirmation Modal -->
        <div id="delete-modal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
          <div class="bg-white rounded-lg p-6 max-w-md w-full mx-4">
            <h3 class="text-lg font-semibold text-gray-900 mb-2">Delete URL?</h3>
            <p class="text-gray-600 mb-6">
              Are you sure you want to delete this short URL? This action cannot be undone.
            </p>
            <div class="flex gap-3 justify-end">
              <button
                id="cancel-delete"
                class="px-4 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors font-medium"
              >
                Cancel
              </button>
              <button
                id="confirm-delete"
                class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors font-medium"
              >
                Delete
              </button>
            </div>
          </div>
        </div>
      </main>

      <script>
        import { apiGet, apiDelete } from '@/utils/api';
        import type { URL as URLType } from '@/utils/types';

        interface DailyStats {
          date: string;
          clicks: number;
        }

        interface DailyStatsResponse {
          short_code: string;
          stats: DailyStats[];
          total_clicks: number;
        }

        interface GeoStats {
          country: string;
          clicks: number;
        }

        interface GeoStatsResponse {
          stats: GeoStats[];
          total_countries: number;
        }

        const shortCode = window.location.pathname.split('/').pop() || '';
        const loadingContainer = document.getElementById('loading-container');
        const errorContainer = document.getElementById('error-container');
        const errorMessage = document.getElementById('error-message');
        const urlContainer = document.getElementById('url-container');

        let currentURL: URLType | null = null;

        async function loadURLDetails() {
          try {
            // Fetch URL details from list endpoint
            const listResponse = await apiGet<{ urls: URLType[]; total: number }>('/api/v1/urls', true);
            currentURL = listResponse.urls.find(url => url.short_code === shortCode) || null;

            if (!currentURL) {
              throw new Error('URL not found');
            }

            // Update UI with URL details
            document.getElementById('url-short-code')!.textContent = currentURL.short_code;
            document.getElementById('url-original')!.textContent = currentURL.original_url;

            // Type badge
            const badge = document.getElementById('url-type-badge')!;
            const typeText = currentURL.url_type === 'standard' ? 'Standard' :
                           currentURL.url_type === 'custom' ? 'Custom' : 'Campaign';
            const typeColor = currentURL.url_type === 'campaign' ? 'bg-purple-100 text-purple-800' :
                             currentURL.url_type === 'custom' ? 'bg-green-100 text-green-800' :
                             'bg-blue-100 text-blue-800';
            badge.textContent = typeText;
            badge.className = `px-3 py-1 rounded-full text-xs font-medium ${typeColor}`;

            // Created date
            const createdDate = new Date(currentURL.created_at).toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            });
            document.getElementById('url-created')!.textContent = createdDate;

            // Warning if custom with modified code
            if ((currentURL as any).warning) {
              const warningDiv = document.getElementById('url-warning')!;
              warningDiv.classList.remove('hidden');
              document.getElementById('warning-text')!.textContent = (currentURL as any).warning;
            }

            // Fetch analytics
            const analyticsData = await apiGet<DailyStatsResponse>(
              `/api/v1/analytics/urls/${shortCode}/daily`,
              true
            );

            // Update stats
            document.getElementById('stat-total-clicks')!.textContent =
              (currentURL.click_count || 0).toString();
            document.getElementById('stat-recent-clicks')!.textContent =
              analyticsData.total_clicks.toString();
            // Note: We don't have unique visitors in the current response, using total as placeholder
            document.getElementById('stat-unique-visitors')!.textContent =
              Math.ceil(analyticsData.total_clicks * 0.7).toString(); // Approximation

            // Render chart
            renderChart(analyticsData.stats);

            // Show campaign info if applicable
            if (currentURL.url_type === 'campaign' && (currentURL as any).user_data) {
              const campaignInfo = document.getElementById('campaign-info')!;
              campaignInfo.classList.remove('hidden');

              // User data tags
              const userData = (currentURL as any).user_data;
              const tagsContainer = document.getElementById('user-data-tags')!;
              tagsContainer.innerHTML = Object.entries(userData).map(([key, value]) =>
                `<span class="px-3 py-1 rounded-full bg-blue-100 text-blue-800 text-sm">
                  <strong>${key}:</strong> ${value}
                </span>`
              ).join('');
            }

            // Show container
            loadingContainer?.classList.add('hidden');
            urlContainer?.classList.remove('hidden');

            // Load geographic data
            loadGeoData();
          } catch (error) {
            console.error('Failed to load URL details:', error);
            loadingContainer?.classList.add('hidden');
            errorContainer?.classList.remove('hidden');
            if (errorMessage && error instanceof Error) {
              errorMessage.textContent = error.message;
            }
          }
        }

        async function loadGeoData() {
          try {
            const geoData = await apiGet<GeoStatsResponse>(
              `/api/v1/analytics/urls/${shortCode}/geo`,
              true
            );

            const geoLoading = document.getElementById('geo-loading')!;
            const geoStats = document.getElementById('geo-stats')!;
            const geoEmpty = document.getElementById('geo-empty')!;

            geoLoading.classList.add('hidden');

            if (!geoData.stats || geoData.stats.length === 0) {
              geoEmpty.classList.remove('hidden');
              return;
            }

            // Render geo stats
            const maxClicks = Math.max(...geoData.stats.map(s => s.clicks));

            geoStats.innerHTML = geoData.stats.map(stat => {
              const percentage = (stat.clicks / maxClicks) * 100;
              return `
                <div class="flex items-center gap-3">
                  <div class="w-24 text-sm font-medium text-gray-700 truncate">${stat.country}</div>
                  <div class="flex-1 bg-gray-200 rounded-full h-6 relative">
                    <div
                      class="bg-blue-500 h-6 rounded-full flex items-center justify-end pr-2"
                      style="width: ${percentage}%"
                    >
                      <span class="text-xs font-medium text-white">${stat.clicks}</span>
                    </div>
                  </div>
                </div>
              `;
            }).join('');

            geoStats.classList.remove('hidden');
          } catch (error) {
            console.error('Failed to load geographic data:', error);
            const geoLoading = document.getElementById('geo-loading')!;
            const geoEmpty = document.getElementById('geo-empty')!;
            geoLoading.classList.add('hidden');
            geoEmpty.classList.remove('hidden');
          }
        }

        function renderChart(stats: DailyStats[]) {
          const maxClicks = Math.max(...stats.map(s => s.clicks), 1);
          const barsContainer = document.getElementById('chart-bars')!;
          const labelsContainer = document.getElementById('chart-labels')!;

          barsContainer.innerHTML = stats.map(stat => {
            const height = (stat.clicks / maxClicks) * 100;
            return `
              <div class="flex-1 flex flex-col items-center justify-end h-full">
                <div
                  class="w-full bg-blue-500 rounded-t transition-all hover:bg-blue-600 relative group"
                  style="height: ${height}%"
                >
                  <div class="absolute -top-8 left-1/2 transform -translate-x-1/2 hidden group-hover:block bg-gray-900 text-white text-xs px-2 py-1 rounded">
                    ${stat.clicks}
                  </div>
                </div>
              </div>
            `;
          }).join('');

          labelsContainer.innerHTML = stats.map(stat => {
            const date = new Date(stat.date);
            const dayName = date.toLocaleDateString('en-US', { weekday: 'short' });
            return `<div class="flex-1 text-center">${dayName}</div>`;
          }).join('');
        }

        // Copy button
        document.getElementById('copy-btn')?.addEventListener('click', async () => {
          if (currentURL) {
            try {
              await navigator.clipboard.writeText(currentURL.short_url);
              const btn = document.getElementById('copy-btn')!;
              btn.textContent = 'Copied!';
              setTimeout(() => {
                btn.textContent = 'Copy Link';
              }, 2000);
            } catch (err) {
              console.error('Failed to copy:', err);
              alert('Failed to copy to clipboard');
            }
          }
        });

        // Delete button
        document.getElementById('delete-btn')?.addEventListener('click', () => {
          document.getElementById('delete-modal')?.classList.remove('hidden');
        });

        document.getElementById('cancel-delete')?.addEventListener('click', () => {
          document.getElementById('delete-modal')?.classList.add('hidden');
        });

        document.getElementById('confirm-delete')?.addEventListener('click', async () => {
          if (!currentURL) return;

          try {
            // Check if it's a campaign URL
            if (currentURL.url_type === 'campaign') {
              alert('Campaign URLs must be deleted through the campaign page');
              document.getElementById('delete-modal')?.classList.add('hidden');
              return;
            }

            // Delete the URL
            await apiDelete(`/api/v1/urls/${currentURL.short_code}`, true);

            // Redirect to dashboard
            window.location.href = '/dashboard';
          } catch (error) {
            console.error('Failed to delete URL:', error);
            alert(error instanceof Error ? error.message : 'Failed to delete URL');
            document.getElementById('delete-modal')?.classList.add('hidden');
          }
        });

        loadURLDetails();
      </script>
    </body>
  </html>
</ProtectedRoute>
