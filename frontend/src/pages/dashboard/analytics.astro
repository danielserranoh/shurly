---
import Layout from '../../layouts/Layout.astro';
import ProtectedRoute from '../../components/ProtectedRoute.astro';
---

<Layout title="Analytics - Shurly">
  <ProtectedRoute>
    <div class="min-h-screen bg-gray-50 py-8">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Header -->
        <div class="mb-8">
          <h1 class="text-3xl font-bold text-gray-900">Analytics Dashboard</h1>
          <p class="mt-2 text-sm text-gray-600">Overview of your URL shortening performance</p>
        </div>

        <!-- Loading State -->
        <div id="loading" class="flex items-center justify-center py-12">
          <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600"></div>
        </div>

        <!-- Content -->
        <div id="content" class="hidden">
          <!-- Summary Stats Cards -->
          <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4 mb-8">
            <!-- Total URLs Card -->
            <div class="bg-white overflow-hidden shadow rounded-lg">
              <div class="p-5">
                <div class="flex items-center">
                  <div class="flex-shrink-0">
                    <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path>
                    </svg>
                  </div>
                  <div class="ml-5 w-0 flex-1">
                    <dl>
                      <dt class="text-sm font-medium text-gray-500 truncate">Total URLs</dt>
                      <dd class="text-2xl font-semibold text-gray-900" id="total-urls">-</dd>
                    </dl>
                  </div>
                </div>
              </div>
            </div>

            <!-- Total Campaigns Card -->
            <div class="bg-white overflow-hidden shadow rounded-lg">
              <div class="p-5">
                <div class="flex items-center">
                  <div class="flex-shrink-0">
                    <svg class="h-6 w-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                    </svg>
                  </div>
                  <div class="ml-5 w-0 flex-1">
                    <dl>
                      <dt class="text-sm font-medium text-gray-500 truncate">Total Campaigns</dt>
                      <dd class="text-2xl font-semibold text-gray-900" id="total-campaigns">-</dd>
                    </dl>
                  </div>
                </div>
              </div>
            </div>

            <!-- Total Clicks Card -->
            <div class="bg-white overflow-hidden shadow rounded-lg">
              <div class="p-5">
                <div class="flex items-center">
                  <div class="flex-shrink-0">
                    <svg class="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122"></path>
                    </svg>
                  </div>
                  <div class="ml-5 w-0 flex-1">
                    <dl>
                      <dt class="text-sm font-medium text-gray-500 truncate">Total Clicks</dt>
                      <dd class="text-2xl font-semibold text-gray-900" id="total-clicks">-</dd>
                    </dl>
                  </div>
                </div>
              </div>
            </div>

            <!-- Unique Visitors Card -->
            <div class="bg-white overflow-hidden shadow rounded-lg">
              <div class="p-5">
                <div class="flex items-center">
                  <div class="flex-shrink-0">
                    <svg class="h-6 w-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                    </svg>
                  </div>
                  <div class="ml-5 w-0 flex-1">
                    <dl>
                      <dt class="text-sm font-medium text-gray-500 truncate">Unique Visitors</dt>
                      <dd class="text-2xl font-semibold text-gray-900" id="unique-visitors">-</dd>
                    </dl>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Recent Activity (Last 7 Days) -->
          <div class="bg-white shadow rounded-lg p-6 mb-8">
            <h2 class="text-lg font-semibold text-gray-900 mb-4">Recent Activity (Last 7 Days)</h2>
            <div class="space-y-1 mb-4">
              <div class="flex justify-between text-sm">
                <span class="text-gray-600">Total Clicks:</span>
                <span class="font-semibold text-gray-900" id="recent-clicks">-</span>
              </div>
            </div>

            <!-- Timeline Chart -->
            <div id="timeline-chart" class="mt-6">
              <!-- Chart will be rendered here -->
            </div>
          </div>

          <!-- Two Column Layout -->
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <!-- Top Performing URLs -->
            <div class="bg-white shadow rounded-lg p-6">
              <h2 class="text-lg font-semibold text-gray-900 mb-4">Top Performing URLs</h2>
              <div id="top-urls" class="space-y-3">
                <!-- Top URLs will be rendered here -->
              </div>
            </div>

            <!-- Export Section -->
            <div class="bg-white shadow rounded-lg p-6">
              <h2 class="text-lg font-semibold text-gray-900 mb-4">Export Data</h2>
              <p class="text-sm text-gray-600 mb-4">Download your analytics data for further analysis</p>
              <button
                id="export-btn"
                class="w-full inline-flex justify-center items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500"
              >
                <svg class="mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
                Export Analytics CSV
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script>
      import { apiGet } from '../../utils/api';
      import type { OverviewStats, DailyStats } from '../../utils/types';

      let overviewData: OverviewStats | null = null;

      async function loadAnalytics() {
        try {
          const data = await apiGet<OverviewStats>('/api/analytics/overview', true);
          overviewData = data;

          // Update summary cards
          document.getElementById('total-urls')!.textContent = data.total_urls.toString();
          document.getElementById('total-campaigns')!.textContent = data.total_campaigns.toString();
          document.getElementById('total-clicks')!.textContent = data.total_clicks.toString();
          document.getElementById('unique-visitors')!.textContent = data.unique_visitors.toString();
          document.getElementById('recent-clicks')!.textContent = data.recent_clicks.toString();

          // Render timeline chart
          renderTimelineChart(data.daily_timeline);

          // Render top URLs
          renderTopURLs(data.top_urls);

          // Show content, hide loading
          document.getElementById('loading')!.classList.add('hidden');
          document.getElementById('content')!.classList.remove('hidden');
        } catch (error) {
          console.error('Failed to load analytics:', error);
          alert('Failed to load analytics data');
        }
      }

      function renderTimelineChart(timeline: DailyStats[]) {
        const container = document.getElementById('timeline-chart')!;

        if (!timeline || timeline.length === 0) {
          container.innerHTML = '<p class="text-gray-500 text-sm text-center py-8">No activity data available</p>';
          return;
        }

        const maxClicks = Math.max(...timeline.map(d => d.clicks), 1);

        const chartHTML = `
          <div class="flex items-end justify-between h-48 gap-2">
            ${timeline.map(stat => {
              const height = (stat.clicks / maxClicks) * 100;
              const date = new Date(stat.date);
              const dayName = date.toLocaleDateString('en-US', { weekday: 'short' });

              return `
                <div class="flex-1 flex flex-col items-center group">
                  <div class="relative w-full">
                    <div
                      class="w-full bg-blue-500 hover:bg-blue-600 rounded-t transition-all cursor-pointer"
                      style="height: ${height}%"
                      title="${stat.clicks} clicks on ${date.toLocaleDateString()}"
                    ></div>
                    <div class="absolute -top-6 left-1/2 transform -translate-x-1/2 bg-gray-900 text-white text-xs px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap">
                      ${stat.clicks} clicks
                    </div>
                  </div>
                  <div class="text-xs text-gray-600 mt-2">${dayName}</div>
                </div>
              `;
            }).join('')}
          </div>
          <div class="mt-4 text-xs text-gray-500 text-center">
            Hover over bars to see exact numbers
          </div>
        `;

        container.innerHTML = chartHTML;
      }

      function renderTopURLs(topUrls: Array<{ short_code: string; short_url: string; clicks: number }>) {
        const container = document.getElementById('top-urls')!;

        if (!topUrls || topUrls.length === 0) {
          container.innerHTML = '<p class="text-gray-500 text-sm text-center py-8">No URL data available</p>';
          return;
        }

        const urlsHTML = topUrls.map((url, index) => `
          <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <div class="flex items-center flex-1 min-w-0">
              <span class="flex-shrink-0 w-6 h-6 flex items-center justify-center bg-blue-600 text-white text-xs font-bold rounded-full mr-3">
                ${index + 1}
              </span>
              <a
                href="/dashboard/urls/${url.short_code}"
                class="text-sm font-medium text-blue-600 hover:text-blue-800 truncate"
              >
                ${url.short_url}
              </a>
            </div>
            <span class="ml-3 text-sm font-semibold text-gray-900">${url.clicks} clicks</span>
          </div>
        `).join('');

        container.innerHTML = urlsHTML;
      }

      function exportAnalyticsCSV() {
        if (!overviewData) {
          alert('No data to export');
          return;
        }

        const csvRows = [];

        // Header
        csvRows.push('Metric,Value');

        // Summary stats
        csvRows.push(`Total URLs,${overviewData.total_urls}`);
        csvRows.push(`Total Campaigns,${overviewData.total_campaigns}`);
        csvRows.push(`Total Clicks,${overviewData.total_clicks}`);
        csvRows.push(`Unique Visitors,${overviewData.unique_visitors}`);
        csvRows.push(`Recent Clicks (7 days),${overviewData.recent_clicks}`);
        csvRows.push('');

        // Daily timeline
        csvRows.push('Daily Timeline');
        csvRows.push('Date,Clicks');
        overviewData.daily_timeline.forEach(day => {
          csvRows.push(`${day.date},${day.clicks}`);
        });
        csvRows.push('');

        // Top URLs
        csvRows.push('Top URLs');
        csvRows.push('Short URL,Clicks');
        overviewData.top_urls.forEach(url => {
          csvRows.push(`${url.short_url},${url.clicks}`);
        });

        const csvContent = csvRows.join('\n');
        const blob = new Blob([csvContent], { type: 'text/csv' });
        const url = window.URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `shurly-analytics-${new Date().toISOString().split('T')[0]}.csv`;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        window.URL.revokeObjectURL(url);
      }

      // Event listeners
      document.getElementById('export-btn')!.addEventListener('click', exportAnalyticsCSV);

      // Load analytics on page load
      loadAnalytics();
    </script>
  </ProtectedRoute>
</Layout>
