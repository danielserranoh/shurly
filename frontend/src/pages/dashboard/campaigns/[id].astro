---
import ProtectedRoute from '@/components/ProtectedRoute.astro';
import Navbar from '@/components/Navbar.astro';

const title = 'Campaign Details | Shurly';
---

<ProtectedRoute>
  <!DOCTYPE html>
  <html lang="en">
    <head>
      <meta charset="UTF-8" />
      <meta name="viewport" content="width=device-width, initial-scale=1.0" />
      <title>{title}</title>
    </head>
    <body class="bg-gray-50 min-h-screen">
      <Navbar />

      <main class="container mx-auto px-4 py-8">
        <!-- Loading State -->
        <div id="loading-container" class="flex items-center justify-center py-12">
          <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600"></div>
          <span class="ml-3 text-gray-600">Loading campaign...</span>
        </div>

        <!-- Error State -->
        <div id="error-container" class="hidden">
          <div class="bg-red-50 border border-red-200 rounded-lg p-4">
            <p class="text-red-800" id="error-message">Failed to load campaign</p>
          </div>
          <div class="mt-4">
            <a
              href="/dashboard/campaigns"
              class="text-blue-600 hover:text-blue-700 text-sm font-medium"
            >
              ← Back to Campaigns
            </a>
          </div>
        </div>

        <!-- Campaign Details -->
        <div id="campaign-container" class="hidden">
          <div class="mb-8">
            <a
              href="/dashboard/campaigns"
              class="text-blue-600 hover:text-blue-700 text-sm font-medium"
            >
              ← Back to Campaigns
            </a>
          </div>

          <!-- Header -->
          <div class="flex items-start justify-between mb-8">
            <div class="flex-1">
              <h1 id="campaign-name" class="text-3xl font-bold text-gray-900"></h1>
              <p id="campaign-url" class="text-gray-600 mt-1"></p>
            </div>
            <div class="flex gap-3">
              <button
                id="export-btn"
                class="border border-gray-300 text-gray-700 px-4 py-2 rounded-lg hover:bg-gray-50 transition-colors font-medium"
              >
                Export CSV
              </button>
              <button
                id="delete-btn"
                class="border border-red-300 text-red-700 px-4 py-2 rounded-lg hover:bg-red-50 transition-colors font-medium"
              >
                Delete Campaign
              </button>
            </div>
          </div>

          <!-- Stats Cards -->
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <div class="bg-white border border-gray-200 rounded-lg p-6">
              <div class="text-sm text-gray-500 mb-1">Total URLs</div>
              <div id="stat-urls" class="text-3xl font-bold text-gray-900">0</div>
            </div>
            <div class="bg-white border border-gray-200 rounded-lg p-6">
              <div class="text-sm text-gray-500 mb-1">CSV Columns</div>
              <div id="stat-columns" class="text-3xl font-bold text-gray-900">0</div>
            </div>
            <div class="bg-white border border-gray-200 rounded-lg p-6">
              <div class="text-sm text-gray-500 mb-1">Created</div>
              <div id="stat-created" class="text-lg font-medium text-gray-900"></div>
            </div>
          </div>

          <!-- Analytics Summary -->
          <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
            <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
              <div class="text-sm text-blue-600 mb-1 font-medium">Total Clicks</div>
              <div id="analytics-clicks" class="text-3xl font-bold text-blue-900">-</div>
            </div>
            <div class="bg-green-50 border border-green-200 rounded-lg p-6">
              <div class="text-sm text-green-600 mb-1 font-medium">Unique Visitors</div>
              <div id="analytics-unique" class="text-3xl font-bold text-green-900">-</div>
            </div>
            <div class="bg-purple-50 border border-purple-200 rounded-lg p-6">
              <div class="text-sm text-purple-600 mb-1 font-medium">Click-Through Rate</div>
              <div id="analytics-ctr" class="text-3xl font-bold text-purple-900">-</div>
            </div>
            <div class="bg-orange-50 border border-orange-200 rounded-lg p-6">
              <div class="text-sm text-orange-600 mb-1 font-medium">Avg Clicks/URL</div>
              <div id="analytics-avg" class="text-3xl font-bold text-orange-900">-</div>
            </div>
          </div>

          <!-- Analytics Charts -->
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
            <!-- Daily Timeline Chart -->
            <div class="bg-white border border-gray-200 rounded-lg p-6">
              <h2 class="text-lg font-semibold text-gray-900 mb-4">Click Timeline (Last 7 Days)</h2>
              <div id="timeline-chart" class="h-64"></div>
            </div>

            <!-- Top Performers -->
            <div class="bg-white border border-gray-200 rounded-lg p-6">
              <h2 class="text-lg font-semibold text-gray-900 mb-4">Top Performers</h2>
              <div id="top-performers" class="space-y-3">
                <div class="text-center text-gray-500 py-8">Loading...</div>
              </div>
            </div>
          </div>

          <!-- CSV Columns -->
          <div class="bg-white border border-gray-200 rounded-lg p-6 mb-6">
            <h2 class="text-lg font-semibold text-gray-900 mb-3">CSV Columns</h2>
            <div id="columns-list" class="flex flex-wrap gap-2"></div>
          </div>

          <!-- URLs Table -->
          <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-200">
              <h2 class="text-lg font-semibold text-gray-900">Campaign URLs</h2>
              <p class="text-sm text-gray-500 mt-1">
                Each URL redirects to the destination with personalized query parameters
              </p>
            </div>

            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                  <tr id="table-header">
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                      Short URL
                    </th>
                  </tr>
                </thead>
                <tbody id="table-body" class="bg-white divide-y divide-gray-200">
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </main>

      <script>
        import { apiGet, apiDelete, apiDownload } from '@/utils/api';
        import type { Campaign } from '@/utils/types';

        const campaignId = window.location.pathname.split('/').pop();

        const loadingContainer = document.getElementById('loading-container');
        const errorContainer = document.getElementById('error-container');
        const errorMessage = document.getElementById('error-message');
        const campaignContainer = document.getElementById('campaign-container');

        interface DailyStat {
          date: string;
          clicks: number;
        }

        interface TopPerformer {
          user_data: Record<string, string>;
          short_code: string;
          clicks: number;
          unique_ips: number;
          last_clicked: string | null;
        }

        interface CampaignAnalytics {
          campaign_id: string;
          campaign_name: string;
          original_url: string;
          total_urls: number;
          total_clicks: number;
          unique_ips: number;
          click_through_rate: number;
          top_performers: TopPerformer[];
          daily_timeline: DailyStat[];
        }

        async function loadAnalytics() {
          try {
            const analytics = await apiGet<CampaignAnalytics>(`/api/v1/analytics/campaigns/${campaignId}/summary`, true);

            // Update analytics summary cards
            document.getElementById('analytics-clicks')!.textContent = analytics.total_clicks.toLocaleString();
            document.getElementById('analytics-unique')!.textContent = analytics.unique_ips.toLocaleString();
            document.getElementById('analytics-ctr')!.textContent = `${analytics.click_through_rate}%`;

            const avgClicks = analytics.total_urls > 0 ? (analytics.total_clicks / analytics.total_urls).toFixed(1) : '0';
            document.getElementById('analytics-avg')!.textContent = avgClicks;

            // Render timeline chart
            renderTimelineChart(analytics.daily_timeline);

            // Render top performers
            renderTopPerformers(analytics.top_performers);
          } catch (error) {
            console.error('Failed to load analytics:', error);
            // Don't block the page if analytics fail, just show defaults
          }
        }

        function renderTimelineChart(timeline: DailyStat[]) {
          const chartContainer = document.getElementById('timeline-chart');
          if (!chartContainer) return;

          const maxClicks = Math.max(...timeline.map(d => d.clicks), 1);

          chartContainer.innerHTML = `
            <div class="flex items-end justify-between h-full gap-2">
              ${timeline.map(day => {
                const height = (day.clicks / maxClicks) * 100;
                const date = new Date(day.date);
                const dayLabel = date.toLocaleDateString('en-US', { weekday: 'short' });

                return `
                  <div class="flex-1 flex flex-col items-center gap-2">
                    <div class="w-full bg-blue-500 rounded-t hover:bg-blue-600 transition-colors relative group"
                         style="height: ${height}%">
                      <div class="absolute -top-8 left-1/2 transform -translate-x-1/2 bg-gray-900 text-white text-xs px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap">
                        ${day.clicks} clicks
                      </div>
                    </div>
                    <div class="text-xs text-gray-600">${dayLabel}</div>
                  </div>
                `;
              }).join('')}
            </div>
          `;
        }

        function renderTopPerformers(performers: TopPerformer[]) {
          const container = document.getElementById('top-performers');
          if (!container) return;

          if (performers.length === 0) {
            container.innerHTML = '<div class="text-center text-gray-500 py-8">No clicks yet</div>';
            return;
          }

          container.innerHTML = performers.map((performer, index) => {
            const userData = Object.entries(performer.user_data)
              .map(([key, value]) => `<span class="text-gray-600">${key}:</span> ${value}`)
              .join(' • ');

            return `
              <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                <div class="flex items-center gap-3 flex-1">
                  <div class="flex items-center justify-center w-8 h-8 rounded-full bg-blue-100 text-blue-600 font-bold text-sm">
                    ${index + 1}
                  </div>
                  <div class="flex-1">
                    <div class="text-sm font-medium text-gray-900">${userData || 'No data'}</div>
                    <div class="text-xs text-gray-500 font-mono">${performer.short_code}</div>
                  </div>
                </div>
                <div class="text-right">
                  <div class="text-lg font-bold text-gray-900">${performer.clicks}</div>
                  <div class="text-xs text-gray-500">${performer.unique_ips} unique</div>
                </div>
              </div>
            `;
          }).join('');
        }

        async function loadCampaign() {
          try {
            const campaign = await apiGet<Campaign>(`/api/v1/campaigns/${campaignId}`, true);

            // Update header
            document.getElementById('campaign-name')!.textContent = campaign.name;
            document.getElementById('campaign-url')!.textContent = campaign.original_url;

            // Update stats
            document.getElementById('stat-urls')!.textContent = campaign.url_count.toString();
            document.getElementById('stat-columns')!.textContent = campaign.csv_columns.length.toString();

            const createdDate = new Date(campaign.created_at).toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            });
            document.getElementById('stat-created')!.textContent = createdDate;

            // Update columns
            const columnsList = document.getElementById('columns-list');
            if (columnsList) {
              columnsList.innerHTML = campaign.csv_columns.map(col =>
                `<span class="inline-flex items-center px-3 py-1.5 rounded-full bg-blue-100 text-blue-800 text-sm font-medium">${col}</span>`
              ).join('');
            }

            // Build table header
            const tableHeader = document.getElementById('table-header');
            if (tableHeader) {
              const columnHeaders = campaign.csv_columns.map(col =>
                `<th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">${col}</th>`
              ).join('');
              tableHeader.innerHTML = `
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Short URL</th>
                ${columnHeaders}
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
              `;
            }

            // Build table body
            const tableBody = document.getElementById('table-body');
            if (tableBody && campaign.urls) {
              tableBody.innerHTML = campaign.urls.map(url => {
                const userData = url.user_data || {};
                const userDataCells = campaign.csv_columns.map(col =>
                  `<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">${userData[col] || '-'}</td>`
                ).join('');

                return `
                  <tr>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <div class="flex items-center space-x-2">
                        <code class="text-sm font-mono text-blue-600">${url.short_url}</code>
                        <button
                          onclick="copyToClipboard('${url.short_url}')"
                          class="text-gray-400 hover:text-gray-600"
                          title="Copy to clipboard"
                        >
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                          </svg>
                        </button>
                      </div>
                    </td>
                    ${userDataCells}
                    <td class="px-6 py-4 whitespace-nowrap text-sm">
                      <a href="${url.short_url}" target="_blank" class="text-blue-600 hover:text-blue-700">Visit</a>
                    </td>
                  </tr>
                `;
              }).join('');
            }

            // Show campaign container
            loadingContainer?.classList.add('hidden');
            campaignContainer?.classList.remove('hidden');
          } catch (error) {
            console.error('Failed to load campaign:', error);
            loadingContainer?.classList.add('hidden');
            errorContainer?.classList.remove('hidden');
            if (errorMessage && error instanceof Error) {
              errorMessage.textContent = error.message;
            }
          }
        }

        // Copy to clipboard function
        (window as any).copyToClipboard = async (text: string) => {
          try {
            await navigator.clipboard.writeText(text);
            alert('Copied to clipboard!');
          } catch (err) {
            console.error('Failed to copy:', err);
          }
        };

        // Export CSV
        document.getElementById('export-btn')?.addEventListener('click', async () => {
          try {
            await apiDownload(`/api/v1/campaigns/${campaignId}/export`, `campaign-${campaignId}.csv`, true);
          } catch (error) {
            console.error('Failed to export:', error);
            alert('Failed to export CSV');
          }
        });

        // Delete campaign
        document.getElementById('delete-btn')?.addEventListener('click', async () => {
          if (!confirm('Are you sure you want to delete this campaign? This will also delete all associated URLs.')) {
            return;
          }

          try {
            await apiDelete(`/api/v1/campaigns/${campaignId}`, true);
            window.location.href = '/dashboard/campaigns';
          } catch (error) {
            console.error('Failed to delete campaign:', error);
            alert('Failed to delete campaign');
          }
        });

        // Load campaign and analytics
        loadCampaign();
        loadAnalytics();
      </script>
    </body>
  </html>
</ProtectedRoute>
