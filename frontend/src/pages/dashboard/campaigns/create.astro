---
import ProtectedRoute from '@/components/ProtectedRoute.astro';
import Navbar from '@/components/Navbar.astro';

const title = 'Create Campaign | Shurly';
---

<ProtectedRoute>
  <!DOCTYPE html>
  <html lang="en">
    <head>
      <meta charset="UTF-8" />
      <meta name="viewport" content="width=device-width, initial-scale=1.0" />
      <title>{title}</title>
    </head>
    <body class="bg-gray-50 min-h-screen">
      <Navbar />

      <main class="container mx-auto px-4 py-8 max-w-4xl">
        <div class="mb-8">
          <a
            href="/dashboard/campaigns"
            class="text-blue-600 hover:text-blue-700 text-sm font-medium"
          >
            ← Back to Campaigns
          </a>
          <h1 class="text-3xl font-bold text-gray-900 mt-4">Create New Campaign</h1>
          <p class="text-gray-600 mt-1">
            Create bulk shortened URLs from a CSV file
          </p>
        </div>

        <!-- Progress Steps -->
        <div class="mb-8">
          <div class="flex items-center justify-between">
            <div class="flex items-center" id="step-indicator-1">
              <div class="flex items-center justify-center w-10 h-10 rounded-full bg-blue-600 text-white font-semibold">
                1
              </div>
              <span class="ml-3 font-medium text-gray-900">Campaign Info</span>
            </div>
            <div class="flex-1 h-0.5 mx-4 bg-gray-300"></div>
            <div class="flex items-center" id="step-indicator-2">
              <div class="flex items-center justify-center w-10 h-10 rounded-full bg-gray-300 text-gray-600 font-semibold">
                2
              </div>
              <span class="ml-3 font-medium text-gray-500">Upload CSV</span>
            </div>
            <div class="flex-1 h-0.5 mx-4 bg-gray-300"></div>
            <div class="flex items-center" id="step-indicator-3">
              <div class="flex items-center justify-center w-10 h-10 rounded-full bg-gray-300 text-gray-600 font-semibold">
                3
              </div>
              <span class="ml-3 font-medium text-gray-500">Review</span>
            </div>
          </div>
        </div>

        <!-- Form Container -->
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-8">
          <!-- Step 1: Campaign Info -->
          <div id="step-1">
            <h2 class="text-xl font-semibold text-gray-900 mb-6">
              Campaign Information
            </h2>

            <div class="space-y-6">
              <div>
                <label for="campaign-name" class="block text-sm font-medium text-gray-700 mb-2">
                  Campaign Name <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  id="campaign-name"
                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                  placeholder="e.g., Q4 2024 Product Launch"
                  required
                />
                <p class="mt-1 text-sm text-gray-500">
                  A descriptive name to identify this campaign
                </p>
              </div>

              <div>
                <label for="original-url" class="block text-sm font-medium text-gray-700 mb-2">
                  Destination URL <span class="text-red-500">*</span>
                </label>
                <input
                  type="url"
                  id="original-url"
                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                  placeholder="https://example.com/landing-page"
                  required
                />
                <p class="mt-1 text-sm text-gray-500">
                  All short URLs will redirect to this URL with personalized query parameters
                </p>
              </div>
            </div>

            <div class="mt-8 flex justify-end">
              <button
                id="next-step-1"
                class="bg-blue-600 text-white px-6 py-2.5 rounded-lg hover:bg-blue-700 transition-colors font-medium"
              >
                Next: Upload CSV →
              </button>
            </div>
          </div>

          <!-- Step 2: CSV Upload -->
          <div id="step-2" class="hidden">
            <h2 class="text-xl font-semibold text-gray-900 mb-6">Upload CSV File</h2>

            <div class="space-y-6">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">
                  CSV Data <span class="text-red-500">*</span>
                </label>
                <textarea
                  id="csv-data"
                  rows="10"
                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent font-mono text-sm"
                  placeholder="firstName,lastName,company,email
John,Doe,Acme Corp,john@acme.com
Jane,Smith,TechCorp,jane@techcorp.com"
                  required
                ></textarea>
                <p class="mt-1 text-sm text-gray-500">
                  Paste your CSV data with a header row. Each row will create one short URL.
                </p>
              </div>

              <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
                <h4 class="text-sm font-medium text-blue-900 mb-2">CSV Format Requirements:</h4>
                <ul class="text-sm text-blue-800 space-y-1 list-disc list-inside">
                  <li>First row must be a header with column names</li>
                  <li>Column names can be anything (e.g., firstName, company, region)</li>
                  <li>All rows must have the same number of columns</li>
                  <li>Each row creates one short URL with that row's data as query parameters</li>
                </ul>
              </div>

              <!-- CSV Preview (shown after validation) -->
              <div id="csv-preview" class="hidden">
                <h3 class="text-sm font-medium text-gray-700 mb-2">Preview:</h3>
                <div class="border border-gray-200 rounded-lg overflow-hidden">
                  <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                      <tr id="csv-preview-header"></tr>
                    </thead>
                    <tbody id="csv-preview-body" class="bg-white divide-y divide-gray-200">
                    </tbody>
                  </table>
                </div>
                <p class="mt-2 text-sm text-gray-500">
                  <span id="csv-row-count">0</span> URLs will be created
                </p>
              </div>
            </div>

            <div class="mt-8 flex justify-between">
              <button
                id="back-step-2"
                class="border border-gray-300 text-gray-700 px-6 py-2.5 rounded-lg hover:bg-gray-50 transition-colors font-medium"
              >
                ← Back
              </button>
              <button
                id="preview-csv"
                class="bg-blue-600 text-white px-6 py-2.5 rounded-lg hover:bg-blue-700 transition-colors font-medium"
              >
                Preview & Continue →
              </button>
            </div>
          </div>

          <!-- Step 3: Review -->
          <div id="step-3" class="hidden">
            <h2 class="text-xl font-semibold text-gray-900 mb-6">Review & Create</h2>

            <div class="space-y-6">
              <div class="bg-gray-50 rounded-lg p-6 space-y-4">
                <div>
                  <h3 class="text-sm font-medium text-gray-500">Campaign Name</h3>
                  <p id="review-name" class="mt-1 text-lg font-medium text-gray-900"></p>
                </div>
                <div>
                  <h3 class="text-sm font-medium text-gray-500">Destination URL</h3>
                  <p id="review-url" class="mt-1 text-gray-900 break-all"></p>
                </div>
                <div>
                  <h3 class="text-sm font-medium text-gray-500">Total URLs</h3>
                  <p id="review-count" class="mt-1 text-lg font-medium text-gray-900"></p>
                </div>
                <div>
                  <h3 class="text-sm font-medium text-gray-500">CSV Columns</h3>
                  <div id="review-columns" class="mt-2 flex flex-wrap gap-2"></div>
                </div>
              </div>

              <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4">
                <p class="text-sm text-yellow-800">
                  <strong>Note:</strong> After creation, each short URL will append its row data as query parameters.
                  For example: <code class="bg-yellow-100 px-1 rounded">?firstName=John&lastName=Doe&company=Acme</code>
                </p>
              </div>
            </div>

            <div class="mt-8 flex justify-between">
              <button
                id="back-step-3"
                class="border border-gray-300 text-gray-700 px-6 py-2.5 rounded-lg hover:bg-gray-50 transition-colors font-medium"
              >
                ← Back
              </button>
              <button
                id="create-campaign"
                class="bg-blue-600 text-white px-6 py-2.5 rounded-lg hover:bg-blue-700 transition-colors font-medium"
              >
                Create Campaign
              </button>
            </div>
          </div>

          <!-- Loading State -->
          <div id="loading-state" class="hidden text-center py-12">
            <div class="inline-flex items-center">
              <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600"></div>
              <span class="ml-3 text-gray-600">Creating campaign...</span>
            </div>
          </div>

          <!-- Error Message -->
          <div id="error-message" class="hidden mt-4 bg-red-50 border border-red-200 rounded-lg p-4">
            <p class="text-red-800" id="error-text"></p>
          </div>
        </div>
      </main>

      <script>
        import { apiPost } from '@/utils/api';
        import type { Campaign, CreateCampaignRequest } from '@/utils/types';

        let currentStep = 1;
        let campaignData: { name: string; original_url: string; csv_data: string } | null = null;
        let parsedCSV: any[] = [];

        // Step navigation
        function goToStep(step: number) {
          // Hide all steps
          document.getElementById('step-1')?.classList.add('hidden');
          document.getElementById('step-2')?.classList.add('hidden');
          document.getElementById('step-3')?.classList.add('hidden');

          // Show target step
          document.getElementById(`step-${step}`)?.classList.remove('hidden');

          // Update step indicators
          for (let i = 1; i <= 3; i++) {
            const indicator = document.getElementById(`step-indicator-${i}`);
            const circle = indicator?.querySelector('div');
            const text = indicator?.querySelector('span');

            if (i < step) {
              // Completed step
              circle?.classList.remove('bg-gray-300', 'text-gray-600');
              circle?.classList.add('bg-green-600', 'text-white');
              text?.classList.remove('text-gray-500');
              text?.classList.add('text-gray-900');
            } else if (i === step) {
              // Current step
              circle?.classList.remove('bg-gray-300', 'text-gray-600', 'bg-green-600');
              circle?.classList.add('bg-blue-600', 'text-white');
              text?.classList.remove('text-gray-500');
              text?.classList.add('text-gray-900');
            } else {
              // Future step
              circle?.classList.remove('bg-blue-600', 'bg-green-600', 'text-white');
              circle?.classList.add('bg-gray-300', 'text-gray-600');
              text?.classList.remove('text-gray-900');
              text?.classList.add('text-gray-500');
            }
          }

          currentStep = step;
        }

        // Step 1: Next button
        document.getElementById('next-step-1')?.addEventListener('click', () => {
          const name = (document.getElementById('campaign-name') as HTMLInputElement)?.value.trim();
          const url = (document.getElementById('original-url') as HTMLInputElement)?.value.trim();

          if (!name) {
            alert('Please enter a campaign name');
            return;
          }

          if (!url || !url.match(/^https?:\/\/.+/)) {
            alert('Please enter a valid URL (must start with http:// or https://)');
            return;
          }

          campaignData = { name, original_url: url, csv_data: '' };
          goToStep(2);
        });

        // Step 2: Back button
        document.getElementById('back-step-2')?.addEventListener('click', () => {
          goToStep(1);
        });

        // Step 2: Preview CSV
        document.getElementById('preview-csv')?.addEventListener('click', () => {
          const csvData = (document.getElementById('csv-data') as HTMLTextAreaElement)?.value.trim();

          if (!csvData) {
            alert('Please paste CSV data');
            return;
          }

          // Parse CSV
          try {
            const lines = csvData.split('\n').filter(line => line.trim());
            if (lines.length < 2) {
              alert('CSV must have at least a header row and one data row');
              return;
            }

            const headers = lines[0].split(',').map(h => h.trim());
            parsedCSV = lines.slice(1).map(line => {
              const values = line.split(',').map(v => v.trim());
              const row: any = {};
              headers.forEach((header, i) => {
                row[header] = values[i] || '';
              });
              return row;
            });

            // Show preview
            const preview = document.getElementById('csv-preview');
            const headerRow = document.getElementById('csv-preview-header');
            const bodyRows = document.getElementById('csv-preview-body');

            if (headerRow) {
              headerRow.innerHTML = headers.map(h =>
                `<th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">${h}</th>`
              ).join('');
            }

            if (bodyRows) {
              bodyRows.innerHTML = parsedCSV.slice(0, 5).map(row =>
                `<tr>${headers.map(h =>
                  `<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">${row[h]}</td>`
                ).join('')}</tr>`
              ).join('');
            }

            const rowCount = document.getElementById('csv-row-count');
            if (rowCount) {
              rowCount.textContent = parsedCSV.length.toString();
            }

            preview?.classList.remove('hidden');

            // Update campaign data
            if (campaignData) {
              campaignData.csv_data = csvData;
            }

            goToStep(3);

            // Update review
            document.getElementById('review-name')!.textContent = campaignData!.name;
            document.getElementById('review-url')!.textContent = campaignData!.original_url;
            document.getElementById('review-count')!.textContent = `${parsedCSV.length} URLs`;

            const columnsContainer = document.getElementById('review-columns');
            if (columnsContainer) {
              columnsContainer.innerHTML = headers.map(h =>
                `<span class="inline-flex items-center px-3 py-1 rounded-full bg-blue-100 text-blue-800 text-sm font-medium">${h}</span>`
              ).join('');
            }

          } catch (error) {
            alert('Failed to parse CSV. Please check the format.');
            console.error(error);
          }
        });

        // Step 3: Back button
        document.getElementById('back-step-3')?.addEventListener('click', () => {
          goToStep(2);
        });

        // Step 3: Create campaign
        document.getElementById('create-campaign')?.addEventListener('click', async () => {
          if (!campaignData) {
            alert('Campaign data is missing');
            return;
          }

          const errorDiv = document.getElementById('error-message');
          const errorText = document.getElementById('error-text');
          const loadingState = document.getElementById('loading-state');
          const step3 = document.getElementById('step-3');

          try {
            // Show loading
            step3?.classList.add('hidden');
            loadingState?.classList.remove('hidden');
            errorDiv?.classList.add('hidden');

            const campaign = await apiPost<Campaign>(
              '/api/campaigns',
              campaignData,
              true
            );

            // Redirect to campaign details
            window.location.href = `/dashboard/campaigns/${campaign.id}`;
          } catch (error) {
            console.error('Failed to create campaign:', error);
            step3?.classList.remove('hidden');
            loadingState?.classList.add('hidden');
            errorDiv?.classList.remove('hidden');
            if (errorText) {
              errorText.textContent = error instanceof Error ? error.message : 'Failed to create campaign';
            }
          }
        });
      </script>
    </body>
  </html>
</ProtectedRoute>
